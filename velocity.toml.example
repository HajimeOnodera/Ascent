# Drop CoreProxy.jar into Velocity's plugins directory. Players join lobby
# first, then use lobby NPCs or commands to move to backend servers.
bind = "0.0.0.0:25565"
online-mode = true
player-info-forwarding-mode = "modern"
forwarding-secret-file = "forwarding.secret"
bungee-plugin-message-channel = true

[servers]
lobby = "127.0.0.1:25567"
skyblock = "127.0.0.1:25566"

try = [
    "lobby",
    "skyblock"
]

[forced-hosts]
